---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';

const categories = ['All', 'Preventive Health', 'Test Preparation', 'Seasonal Health', 'Women\'s Health', 'Lifestyle', 'Lab Updates'];

const placeholderPosts = [
  { title: 'Why you should get a full-body checkup every year', excerpt: 'Preventive health checkups can detect silent conditions like diabetes, high cholesterol, and thyroid disorders.', category: 'Preventive Health', readTime: '4 min' },
  { title: 'How to prepare for a blood test: fasting tips', excerpt: 'Not sure if you need to fast? A complete guide to preparing for common blood tests.', category: 'Test Preparation', readTime: '3 min' },
  { title: 'Monsoon health: tests you should get this season', excerpt: 'Dengue, malaria, and typhoid spike during rains. Know which tests to prioritise.', category: 'Seasonal Health', readTime: '5 min' },
  { title: 'Understanding your thyroid report: T3, T4, and TSH', excerpt: 'What do T3, T4, and TSH levels mean? A pathologist explains your thyroid report in plain language.', category: 'Test Preparation', readTime: '6 min' },
  { title: 'Vitamin D deficiency in Pune: why it matters', excerpt: 'Despite sunny weather, many in Pune are Vitamin D deficient. Here\'s what you need to know.', category: 'Preventive Health', readTime: '4 min' },
  { title: 'What your CBC report tells you about your health', excerpt: 'A complete blood count is the most common blood test. Learn to read your CBC report.', category: 'Test Preparation', readTime: '5 min' },
];
---

<BaseLayout
  title="Health Blog — Expert Tips & Test Guides | HealthAura Pathology Lab Pune"
  description="Read health tips, test preparation guides, and wellness advice from Dr. Prachi Bhagwat and the HealthAura team. Stay informed about your diagnostic health."
  canonicalUrl="/blog"
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-teal-50 via-white to-green-50 py-16 md:py-20">
      <div class="container">
        <nav class="text-sm text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-teal-600 transition-colors">Home</a>
          <span class="mx-2">›</span>
          <span class="text-dark font-medium">Blog</span>
        </nav>
        <span class="section-label">Health Blog</span>
        <h1 class="section-title text-4xl md:text-5xl">Expert health tips & guides</h1>
        <p class="section-subtitle text-lg">
          Stay informed with articles from our medical team — test preparation guides, seasonal health alerts, and wellness advice.
        </p>
      </div>
    </section>

    <!-- Category Filter -->
    <section class="bg-white border-b border-gray-100 sticky top-[60px] md:top-[64px] z-20">
      <div class="container overflow-x-auto">
        <div class="flex gap-1 py-3 min-w-max">
          {categories.map((cat, i) => (
            <button class={`px-4 py-1.5 text-xs font-600 rounded-full transition-colors ${i === 0 ? 'bg-teal-600 text-white' : 'text-muted hover:text-teal-600 hover:bg-teal-50'}`}>
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="py-12 md:py-16 bg-white">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {placeholderPosts.map((post, i) => (
            <article class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group" data-reveal style={`animation-delay: ${i * 80}ms`}>
              <div class="aspect-[16/10] bg-gradient-to-br from-teal-50 to-green-50 flex items-center justify-center">
                <div class="text-center p-6">
                  <i data-lucide="file-text" class="w-10 h-10 text-teal-200 mx-auto mb-2"></i>
                  <p class="text-teal-300 text-xs">Blog image — Phase 2</p>
                </div>
              </div>
              <div class="p-5">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs font-600 text-teal-600 bg-teal-50 px-2.5 py-0.5 rounded-full">{post.category}</span>
                  <span class="text-xs text-muted">{post.readTime}</span>
                </div>
                <h2 class="text-base font-700 text-dark mb-2 group-hover:text-teal-600 transition-colors leading-snug">{post.title}</h2>
                <p class="text-sm text-muted leading-relaxed line-clamp-2">{post.excerpt}</p>
                <div class="mt-4 pt-3 border-t border-gray-50">
                  <span class="text-xs text-teal-600 font-600">Coming soon →</span>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-10 bg-teal-50 rounded-xl p-6 text-center" data-reveal>
          <i data-lucide="database" class="w-8 h-8 text-teal-300 mx-auto mb-3"></i>
          <h3 class="text-lg font-700 text-teal-800 mb-2">Blog powered by Supabase — coming in Phase 2</h3>
          <p class="text-sm text-teal-600 max-w-lg mx-auto">
            Blog content will be managed through the admin panel and served via Supabase database with Edge Functions. These are placeholder containers showing the final layout.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</BaseLayout>
