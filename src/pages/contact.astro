---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
const whatsappUrl = 'https://wa.me/917028022588?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20HealthAura%20Pathology%20Lab';
---

<BaseLayout
  title="Contact HealthAura Pathology Lab Pune — Phone, WhatsApp, Directions"
  description="Contact HealthAura Pathology Laboratory. Call +91 70280 22588 or WhatsApp us. Labs in Baner & Ravet, Pune. Book tests, schedule home visits, or ask about reports."
  canonicalUrl="/contact"
>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-teal-50 via-white to-green-50 py-16 md:py-20">
      <div class="container">
        <nav class="text-sm text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-teal-600 transition-colors">Home</a>
          <span class="mx-2">›</span>
          <span class="text-dark font-medium">Contact</span>
        </nav>
        <span class="section-label">Get in Touch</span>
        <h1 class="section-title text-4xl md:text-5xl">Contact us</h1>
        <p class="section-subtitle text-lg">
          Have a question, need to book a test, or want to discuss your reports? We're here to help.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-white">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
          <!-- Contact Info -->
          <div class="lg:col-span-2 space-y-6" data-reveal>
            <div class="bg-teal-50 rounded-xl p-6">
              <h3 class="text-sm font-700 text-teal-800 uppercase tracking-wide mb-4">Quick Contact</h3>
              <div class="space-y-4">
                <a href="tel:+917028022588" class="flex items-center gap-3 text-teal-700 hover:text-teal-900 transition-colors">
                  <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center flex-shrink-0">
                    <i data-lucide="phone" class="w-5 h-5 text-teal-600"></i>
                  </div>
                  <div>
                    <p class="text-sm font-600">+91 70280 22588</p>
                    <p class="text-xs text-teal-500">Tap to call</p>
                  </div>
                </a>
                <a href={whatsappUrl} target="_blank" rel="noopener" class="flex items-center gap-3 text-teal-700 hover:text-teal-900 transition-colors">
                  <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                    <i data-lucide="message-circle" class="w-5 h-5 text-green-600"></i>
                  </div>
                  <div>
                    <p class="text-sm font-600">WhatsApp Us</p>
                    <p class="text-xs text-teal-500">Quick response</p>
                  </div>
                </a>
              </div>
            </div>

            <div class="bg-gray-50 rounded-xl p-6">
              <h3 class="text-sm font-700 text-dark uppercase tracking-wide mb-4">Lab Addresses</h3>
              <div class="space-y-4">
                <div>
                  <p class="text-sm font-600 text-dark mb-1">Baner Branch</p>
                  <p class="text-sm text-muted">Tulip Towers, First Floor, Baner Road, Opp Primrose Mall, Pune — 411045</p>
                </div>
                <div>
                  <p class="text-sm font-600 text-dark mb-1">Ravet Branch</p>
                  <p class="text-sm text-muted">103, Twin Towers, SB Patil College Road, Near Kotak Bank, Ravet — 412101</p>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-xl p-6">
              <h3 class="text-sm font-700 text-dark uppercase tracking-wide mb-4">Operating Hours</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between"><span class="text-muted">Monday – Saturday</span><span class="font-600 text-dark">8:00 AM – 9:00 PM</span></div>
                <div class="flex justify-between"><span class="text-muted">Sunday</span><span class="font-600 text-dark">8:00 AM – 2:00 PM</span></div>
                <div class="flex justify-between"><span class="text-muted">Home Collection</span><span class="font-600 text-teal-600">From 7:00 AM daily</span></div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="lg:col-span-3" data-reveal>
            <div class="bg-white rounded-xl border border-gray-200 p-8">
              <h2 class="text-xl font-700 text-dark mb-6">Send us a message</h2>
              <form class="space-y-5" id="contact-form">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="name" class="block text-sm font-600 text-dark mb-1.5">Full Name *</label>
                    <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="Your name" />
                  </div>
                  <div>
                    <label for="phone" class="block text-sm font-600 text-dark mb-1.5">Phone Number *</label>
                    <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="+91 XXXXX XXXXX" />
                  </div>
                </div>
                <div>
                  <label for="email" class="block text-sm font-600 text-dark mb-1.5">Email Address</label>
                  <input type="email" id="email" name="email" class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all" placeholder="you@example.com" />
                </div>
                <div>
                  <label for="subject" class="block text-sm font-600 text-dark mb-1.5">Subject</label>
                  <select id="subject" name="subject" class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all bg-white">
                    <option value="">Select a topic</option>
                    <option value="book-test">Book a Test</option>
                    <option value="home-collection">Home Sample Collection</option>
                    <option value="report-query">Report Query</option>
                    <option value="pricing">Pricing & Packages</option>
                    <option value="feedback">Feedback</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label for="message" class="block text-sm font-600 text-dark mb-1.5">Message *</label>
                  <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all resize-none" placeholder="Tell us how we can help..."></textarea>
                </div>
                <button type="submit" class="btn-primary w-full justify-center">
                  <i data-lucide="send" class="w-4 h-4"></i>
                  Send Message
                </button>
                <p class="text-xs text-muted text-center">For faster response, <a href={whatsappUrl} target="_blank" rel="noopener" class="text-teal-600 font-600 hover:underline">WhatsApp us directly</a></p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</BaseLayout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Phase 2: Connect to Supabase edge function
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('#name') as HTMLInputElement)?.value;
    const phone = (form.querySelector('#phone') as HTMLInputElement)?.value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement)?.value;
    const text = `Contact Form Submission:\nName: ${name}\nPhone: ${phone}\nMessage: ${message}`;
    window.open(`https://wa.me/917028022588?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>
