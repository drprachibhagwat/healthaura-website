---
const whatsappUrl = 'https://wa.me/917028022588?text=Hi%2C%20I%27d%20like%20to%20book%20an%20appointment%20at%20HealthAura%20Pathology%20Lab';
---

<section class="py-16 md:py-20 bg-gradient-to-r from-teal-600 to-green-600 text-white" data-reveal>
  <div class="container text-center">
    <h2 class="text-3xl md:text-4xl font-700 mb-4">Ready to take charge of your health?</h2>
    <p class="text-teal-100 text-lg max-w-xl mx-auto mb-8">
      Book your test today. Walk in at our Baner or Ravet lab, or schedule a home visit — your choice.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp text-base !py-3 !px-8">
        <i data-lucide="message-circle" class="w-5 h-5"></i>
        Book on WhatsApp
      </a>
      <a href="tel:+917028022588" class="inline-flex items-center gap-2 px-8 py-3 bg-white/15 hover:bg-white/25 text-white font-600 rounded-lg transition-colors">
        <i data-lucide="phone" class="w-5 h-5"></i>
        Call +91 70280 22588
      </a>
    </div>
  </div>
</section>
