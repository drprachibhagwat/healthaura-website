---
import tests from '../data/tests.json';

const iconColors = [
  'bg-red-50 text-red-500 group-hover:bg-red-500',
  'bg-blue-50 text-blue-500 group-hover:bg-blue-500',
  'bg-pink-50 text-pink-500 group-hover:bg-pink-500',
  'bg-amber-50 text-amber-600 group-hover:bg-amber-600',
  'bg-purple-50 text-purple-500 group-hover:bg-purple-500',
  'bg-orange-50 text-orange-500 group-hover:bg-orange-500',
  'bg-emerald-50 text-emerald-500 group-hover:bg-emerald-500',
  'bg-cyan-50 text-cyan-600 group-hover:bg-cyan-600',
  'bg-indigo-50 text-indigo-500 group-hover:bg-indigo-500',
  'bg-teal-50 text-teal-600 group-hover:bg-teal-600',
  'bg-rose-50 text-rose-500 group-hover:bg-rose-500',
];
---

<section class="py-20 md:py-24 bg-white" id="tests">
  <div class="container">
    <div class="text-center mb-14" data-reveal>
      <span class="section-label">Our Tests</span>
      <h2 class="text-3xl md:text-[2.75rem] font-800 text-dark leading-[1.1] mb-4">Browse tests by category</h2>
      <p class="section-subtitle mx-auto">
        From routine blood work to specialized cancer screening — all tests performed under expert supervision with rapid, reliable results.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {tests.map((cat, i) => (
        <a href={`/tests-and-packages#${cat.id}`}
           class="group bg-white rounded-2xl border-2 border-gray-100 p-6 hover:border-teal-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden"
           data-reveal style={`animation-delay: ${i * 60}ms`}>
          {/* Subtle gradient on hover */}
          <div class="absolute inset-0 bg-gradient-to-br from-teal-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="flex items-start gap-4 mb-4">
              <div class={`w-14 h-14 rounded-2xl ${iconColors[i % iconColors.length]} flex items-center justify-center flex-shrink-0 group-hover:text-white transition-all duration-300 group-hover:shadow-lg`}>
                <i data-lucide={cat.icon} class="w-7 h-7"></i>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-[1.05rem] font-800 text-dark mb-1 group-hover:text-teal-700 transition-colors">{cat.name}</h3>
                <p class="text-muted text-sm leading-relaxed line-clamp-2">{cat.description}</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5 mt-3 pt-3 border-t border-gray-100">
              {cat.tests.slice(0, 3).map(test => (
                <span class="text-xs bg-gray-100 group-hover:bg-white text-muted px-2.5 py-1 rounded-full font-medium transition-colors">{test}</span>
              ))}
              {cat.tests.length > 3 && (
                <span class="text-xs text-teal-600 font-700 px-2.5 py-1">+{cat.tests.length - 3} more</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-12" data-reveal>
      <a href="/tests-and-packages" class="btn-primary text-base !py-3 !px-8">
        View all tests & packages
        <i data-lucide="arrow-right" class="w-5 h-5"></i>
      </a>
    </div>
  </div>
</section>
