---
import packages from '../data/packages.json';
const whatsappUrl = 'https://wa.me/917028022588?text=Hi%2C%20I%27d%20like%20to%20book%20the%20';
---

<section class="py-16 md:py-20 bg-light" id="packages">
  <div class="container">
    <div class="text-center mb-12" data-reveal>
      <span class="section-label">Health Packages</span>
      <h2 class="section-title">Preventive health checkup packages</h2>
      <p class="section-subtitle mx-auto">
        Comprehensive screening packages designed for every age and need. Each package is curated and reviewed by our MD Pathologist.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {packages.map((pkg, i) => (
        <div class={`bg-white rounded-xl border ${i === 1 ? 'border-teal-300 ring-2 ring-teal-100' : 'border-gray-100'} overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col`} data-reveal style={`animation-delay: ${i * 100}ms`}>
          <!-- Tag -->
          <div class={`px-5 py-2 text-xs font-700 uppercase tracking-wide ${i === 1 ? 'bg-teal-600 text-white' : 'bg-gray-50 text-muted'}`}>
            {pkg.tag}
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-lg font-700 text-dark mb-2">{pkg.name}</h3>
            <p class="text-muted text-sm leading-relaxed mb-4">{pkg.description}</p>
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-teal-50 text-teal-700 text-xs font-600 px-2.5 py-1 rounded-full">
                {pkg.testsIncluded} tests included
              </span>
              <span class="text-xs text-muted">{pkg.idealFor}</span>
            </div>
            <!-- Key tests -->
            <div class="flex-1 mb-5">
              <ul class="space-y-1.5">
                {pkg.keyTests.slice(0, 6).map(test => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <i data-lucide="check" class="w-3.5 h-3.5 text-green-500 flex-shrink-0"></i>
                    {test}
                  </li>
                ))}
                {pkg.keyTests.length > 6 && (
                  <li class="text-xs text-teal-600 font-medium pl-5">+ {pkg.keyTests.length - 6} more tests</li>
                )}
              </ul>
            </div>
            <!-- Price placeholder + CTA -->
            <div class="border-t border-gray-100 pt-4 mt-auto">
              <p class="text-xs text-muted mb-3">Price available on enquiry</p>
              <a href={`${whatsappUrl}${encodeURIComponent(pkg.name)}%20package`} target="_blank" rel="noopener"
                 class={`w-full text-center ${i === 1 ? 'btn-primary' : 'btn-secondary'} !py-2.5 justify-center text-sm`}>
                <i data-lucide="message-circle" class="w-4 h-4"></i>
                Enquire & Book
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
