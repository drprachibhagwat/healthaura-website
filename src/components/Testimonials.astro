---
import testimonials from '../data/testimonials.json';
const banerPlaceId = 'ChIJMRcjfde-wjsRdVJygakkt2w';
const ravetPlaceId = 'ChIJt5ml4Xy7wjsRdDT5c03luko';
---

<section class="py-16 md:py-20 bg-light" id="testimonials">
  <div class="container">
    <div class="text-center mb-12" data-reveal>
      <span class="section-label">Patient Reviews</span>
      <h2 class="section-title">Trusted by thousands in Pune</h2>
      <p class="section-subtitle mx-auto">
        Real reviews from Google — rated 4.7+ across both locations with 400+ verified reviews.
      </p>
    </div>
    <!-- Google Reviews Container (populated by API) -->
    <div id="google-reviews" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- Loading skeleton -->
      {[1,2,3,4,5,6].map(() => (
        <div class="bg-white rounded-xl border border-gray-100 p-6 animate-pulse">
          <div class="flex gap-0.5 mb-3">
            {[1,2,3,4,5].map(() => <div class="w-4 h-4 bg-gray-200 rounded"></div>)}
          </div>
          <div class="space-y-2 mb-5">
            <div class="h-3 bg-gray-200 rounded w-full"></div>
            <div class="h-3 bg-gray-200 rounded w-5/6"></div>
            <div class="h-3 bg-gray-200 rounded w-4/6"></div>
          </div>
          <div class="flex items-center gap-3 border-t border-gray-50 pt-4">
            <div class="w-10 h-10 rounded-full bg-gray-200"></div>
            <div class="space-y-1.5">
              <div class="h-3 bg-gray-200 rounded w-24"></div>
              <div class="h-2 bg-gray-200 rounded w-16"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Fallback: Static reviews (shown if API fails) -->
    <div id="static-reviews" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {testimonials.map((review, i) => (
        <div class="bg-white rounded-xl border border-gray-100 p-6 hover:shadow-md transition-shadow" data-reveal style={`animation-delay: ${i * 80}ms`}>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: review.rating }).map(() => (
              <i data-lucide="star" class="w-4 h-4 text-amber-400 fill-amber-400"></i>
            ))}
          </div>
          <!-- Quote -->
          <p class="text-gray-600 text-[0.938rem] leading-relaxed mb-5">"{review.text}"</p>
          <!-- Author -->
          <div class="flex items-center justify-between border-t border-gray-50 pt-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-700 text-sm">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-600 text-dark">{review.name}</p>
                <p class="text-xs text-muted">{review.location}</p>
              </div>
            </div>
            <span class="text-xs bg-teal-50 text-teal-700 px-2 py-1 rounded-full font-medium">{review.service}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-8" data-reveal>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={`https://search.google.com/local/reviews?placeid=${banerPlaceId}`} target="_blank" rel="noopener" class="text-teal-600 font-600 text-sm hover:text-teal-700 inline-flex items-center gap-1.5">
          Baner reviews on Google
          <i data-lucide="external-link" class="w-4 h-4"></i>
        </a>
        <span class="text-gray-300 hidden sm:inline">|</span>
        <a href={`https://search.google.com/local/reviews?placeid=${ravetPlaceId}`} target="_blank" rel="noopener" class="text-teal-600 font-600 text-sm hover:text-teal-700 inline-flex items-center gap-1.5">
          Ravet reviews on Google
          <i data-lucide="external-link" class="w-4 h-4"></i>
        </a>
      </div>
      <p class="text-xs text-muted mt-3" id="google-attr">
        <img src="https://www.gstatic.com/images/branding/googlelogo/2x/googlelogo_color_74x24dp.png" alt="Google" class="inline h-3.5 -mt-0.5 mr-1" loading="lazy" />
        Reviews powered by Google Places
      </p>
    </div>
  </div>
</section>
<!-- Hidden div for Places API -->
<div id="places-attribution" style="display:none"></div>

<script define:vars={{ banerPlaceId, ravetPlaceId }}>
  const GOOGLE_API_KEY = 'AIzaSyDPBUP5I39JfezsFMjcYzuziEbr1EojHPk';

  function renderReviews(reviews) {
    const container = document.getElementById('google-reviews');
    if (!reviews.length) { showFallback(); return; }
    container.innerHTML = reviews.map(r => `
      <div class="bg-white rounded-xl border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <div class="flex gap-0.5 mb-3">
          ${Array.from({length: r.rating}, () => `
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          `).join('')}
        </div>
        <p class="text-gray-600 text-[0.938rem] leading-relaxed mb-5">"${r.text.length > 200 ? r.text.substring(0, 200) + '...' : r.text}"</p>
        <div class="flex items-center justify-between border-t border-gray-50 pt-4">
          <div class="flex items-center gap-3">
            ${r.profile_photo_url
              ? `<img src="${r.profile_photo_url}" alt="${r.author_name}" class="w-10 h-10 rounded-full object-cover" />`
              : `<div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm">${r.author_name.charAt(0)}</div>`
            }
            <div>
              <p class="text-sm font-semibold text-gray-900">${r.author_name}</p>
              <p class="text-xs text-gray-500">${r.relative_time_description}</p>
            </div>
          </div>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full font-medium">${r.branch || 'Google'}</span>
        </div>
      </div>
    `).join('');
  }

  function showFallback() {
    document.getElementById('google-reviews').classList.add('hidden');
    document.getElementById('static-reviews').classList.remove('hidden');
    document.getElementById('google-attr').style.display = 'none';
    if (window.lucide) window.lucide.createIcons();
  }

  async function loadGoogleReviews() {
    if (!GOOGLE_API_KEY) { showFallback(); return; }
    try {
      const script = document.createElement('script');
      script.src = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_API_KEY}&libraries=places`;
      script.async = true;
      script.onload = () => {
        const service = new google.maps.places.PlacesService(document.getElementById('places-attribution'));
        const allReviews = [];
        let loaded = 0;
        [{id: banerPlaceId, branch: 'Baner'}, {id: ravetPlaceId, branch: 'Ravet'}].forEach(loc => {
          service.getDetails({placeId: loc.id, fields: ['reviews']}, (place, status) => {
            loaded++;
            if (status === google.maps.places.PlacesServiceStatus.OK && place.reviews) {
              place.reviews.forEach(r => { r.branch = loc.branch; allReviews.push(r); });
            }
            if (loaded === 2) {
              allReviews.sort((a, b) => b.time - a.time);
              renderReviews(allReviews.filter(r => r.rating >= 4).slice(0, 6));
            }
          });
        });
      };
      script.onerror = showFallback;
      document.head.appendChild(script);
    } catch { showFallback(); }
  }

  document.addEventListener('DOMContentLoaded', loadGoogleReviews);
</script>

