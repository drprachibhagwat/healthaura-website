---
const stats = [
  { icon: 'calendar-check', value: '12+', label: 'Years of Trust' },
  { icon: 'map-pin', value: '2', label: 'Locations in Pune' },
  { icon: 'star', value: '4.7★', label: 'Google Rating' },
  { icon: 'test-tubes', value: '500+', label: 'Tests Available' },
];
---

<section class="relative -mt-1 z-10">
  <div class="container">
    <div class="bg-gradient-to-r from-teal-700 via-teal-800 to-teal-900 rounded-2xl shadow-xl shadow-teal-900/20 px-6 py-5 -mt-8 relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-0 md:divide-x md:divide-teal-600/40">
        {stats.map(stat => (
          <div class="flex items-center justify-center gap-3.5 px-4 py-2" data-reveal>
            <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
              <i data-lucide={stat.icon} class="w-5 h-5 text-teal-200"></i>
            </div>
            <div>
              <div class="text-2xl font-800 text-white leading-none tracking-tight">{stat.value}</div>
              <div class="text-[0.7rem] text-teal-200/80 mt-0.5 font-medium uppercase tracking-wider">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
