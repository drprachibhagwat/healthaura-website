---
const locations = [
  {
    name: 'HealthAura — Baner',
    address: 'Office No. 203, First Floor, Tulip Towers, Baner Road, Opp Primrose Mall',
    city: 'Baner, Pune — 411045',
    phone: '+91 70280 22588',
    rating: '4.7',
    reviews: '273',
    hours: 'Mon–Sat: 8AM–9PM · Sun: 8AM–2PM',
    placeId: 'ChIJMRcjfde-wjsRdVJygakkt2w',
    directionsUrl: 'https://www.google.com/maps/place/?q=place_id:ChIJMRcjfde-wjsRdVJygakkt2w',
    lat: 18.5618819,
    lng: 73.7850432,
  },
  {
    name: 'HealthAura — Ravet',
    address: 'Shop No. 103, C&D Wing, Twin Towers, SB Patil College Road, Near Kotak Bank',
    city: 'Ravet, Pune — 412101',
    phone: '+91 70305 55800',
    rating: '4.9',
    reviews: '135',
    hours: 'Mon–Sat: 8AM–9PM · Sun: 8AM–2PM',
    placeId: 'ChIJt5ml4Xy7wjsRdDT5c03luko',
    directionsUrl: 'https://www.google.com/maps/place/?q=place_id:ChIJt5ml4Xy7wjsRdDT5c03luko',
    lat: 18.64779,
    lng: 73.7432677,
  },
];
---

<section class="py-16 md:py-20 bg-white" id="locations">
  <div class="container">
    <div class="text-center mb-12" data-reveal>
      <span class="section-label">Our Locations</span>
      <h2 class="section-title">Visit us in Baner or Ravet</h2>
      <p class="section-subtitle mx-auto">
        Two conveniently located labs in Pune, equipped with the same high standards and expert staff.
      </p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {locations.map((loc, i) => (
        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow" data-reveal style={`animation-delay: ${i * 150}ms`}>
          <!-- Google Map Embed -->
          <div class="aspect-[16/9] bg-gray-100">
            <iframe
              src={`https://www.google.com/maps?q=${loc.lat},${loc.lng}&z=16&output=embed`}
              class="w-full h-full border-0"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map to ${loc.name}`}>
            </iframe>
          </div>
          <!-- Info -->
          <div class="p-6">
            <a href={`https://search.google.com/local/reviews?placeid=${loc.placeId}`} target="_blank" rel="noopener" class="flex items-center gap-1 bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full text-xs font-600 hover:bg-amber-100 transition-colors">
                <i data-lucide="star" class="w-3 h-3 fill-amber-400 text-amber-400"></i>
                {loc.rating} ({loc.reviews})
              </a>
            </div>
            <div class="space-y-2.5 text-sm text-muted mb-5">
              <div class="flex items-start gap-2.5">
                <i data-lucide="map-pin" class="w-4 h-4 text-teal-500 mt-0.5 flex-shrink-0"></i>
                <span>{loc.address}<br/>{loc.city}</span>
              </div>
              <div class="flex items-center gap-2.5">
                <i data-lucide="phone" class="w-4 h-4 text-teal-500 flex-shrink-0"></i>
                <a href={`tel:${loc.phone.replace(/\s/g, '')}`} class="hover:text-teal-600 transition-colors">{loc.phone}</a>
              </div>
              <div class="flex items-center gap-2.5">
                <i data-lucide="clock" class="w-4 h-4 text-teal-500 flex-shrink-0"></i>
                <span>{loc.hours}</span>
              </div>
            </div>
            <a href={loc.directionsUrl} target="_blank" rel="noopener" class="btn-secondary w-full justify-center text-sm !py-2.5">
              <i data-lucide="navigation" class="w-4 h-4"></i>
              Get Directions
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
