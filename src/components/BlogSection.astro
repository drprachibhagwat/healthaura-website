---
const placeholderPosts = [
  {
    title: 'Why you should get a full-body checkup every year',
    excerpt: 'Preventive health checkups can detect silent conditions like diabetes, high cholesterol, and thyroid disorders before they become serious.',
    category: 'Preventive Health',
    readTime: '4 min read',
    date: 'Coming Soon',
  },
  {
    title: 'How to prepare for a blood test: fasting tips and dos & don\'ts',
    excerpt: 'Not sure if you need to fast? Here\'s a complete guide to preparing for common blood tests for the most accurate results.',
    category: 'Test Preparation',
    readTime: '3 min read',
    date: 'Coming Soon',
  },
  {
    title: 'Monsoon health: tests you should get this season',
    excerpt: 'Dengue, malaria, and typhoid spike during rains. Know which tests to get and when to see a doctor during monsoon season.',
    category: 'Seasonal Health',
    readTime: '5 min read',
    date: 'Coming Soon',
  },
];
---

<section class="py-16 md:py-20 bg-white" id="blog">
  <div class="container">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-12" data-reveal>
      <div>
        <span class="section-label">Health Blog</span>
        <h2 class="section-title">Expert health tips & insights</h2>
        <p class="section-subtitle">
          Stay informed with articles from Dr. Bhagwat and our medical team.
        </p>
      </div>
      <a href="/blog" class="btn-secondary text-sm flex-shrink-0">
        All Articles
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {placeholderPosts.map((post, i) => (
        <article class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group" data-reveal style={`animation-delay: ${i * 100}ms`}>
          <!-- Image placeholder -->
          <div class="aspect-[16/10] bg-gradient-to-br from-teal-50 to-green-50 flex items-center justify-center">
            <div class="text-center p-6">
              <i data-lucide="file-text" class="w-10 h-10 text-teal-200 mx-auto mb-2"></i>
              <p class="text-teal-300 text-xs">Blog image placeholder</p>
            </div>
          </div>
          <div class="p-5">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-600 text-teal-600 bg-teal-50 px-2.5 py-0.5 rounded-full">{post.category}</span>
              <span class="text-xs text-muted">{post.readTime}</span>
            </div>
            <h3 class="text-base font-700 text-dark mb-2 group-hover:text-teal-600 transition-colors leading-snug">{post.title}</h3>
            <p class="text-sm text-muted leading-relaxed line-clamp-2">{post.excerpt}</p>
            <div class="mt-4 pt-3 border-t border-gray-50 flex items-center justify-between">
              <span class="text-xs text-muted">{post.date}</span>
              <span class="text-xs text-teal-600 font-600 group-hover:underline">Read more →</span>
            </div>
          </div>
        </article>
      ))}
    </div>
    <!-- Phase 2 note -->
    <div class="mt-8 bg-teal-50 rounded-xl p-5 text-center" data-reveal>
      <p class="text-sm text-teal-700">
        <i data-lucide="info" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i>
        Blog content coming soon — articles will be managed via admin panel and powered by Supabase.
      </p>
    </div>
  </div>
</section>
